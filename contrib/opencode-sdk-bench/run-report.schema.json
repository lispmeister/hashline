{
  "$defs": {
    "attemptResult": {
      "properties": {
        "attempt": {
          "minimum": 1,
          "type": "integer"
        },
        "corruptionDetected": {
          "type": "boolean"
        },
        "corruptionReason": {
          "type": "string"
        },
        "events": {
          "items": {
            "properties": {
              "command": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "sessionID": {
                "type": "string"
              },
              "timestamp": {
                "type": "number"
              },
              "type": {
                "type": "string"
              }
            },
            "required": [
              "timestamp",
              "type"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "metrics": {
          "properties": {
            "changedLines": {
              "type": "integer"
            },
            "cost": {
              "type": "number"
            },
            "durationMs": {
              "minimum": 0,
              "type": "number"
            },
            "errorCount": {
              "minimum": 0,
              "type": "integer"
            },
            "expectedChangedLines": {
              "type": "integer"
            },
            "retries": {
              "minimum": 0,
              "type": "integer"
            },
            "tokenInput": {
              "type": "number"
            },
            "tokenOutput": {
              "type": "number"
            },
            "tokenReasoning": {
              "type": "number"
            },
            "tokenTotal": {
              "type": "number"
            },
            "unexpectedChangedLines": {
              "type": "integer"
            }
          },
          "required": [
            "durationMs",
            "retries",
            "errorCount"
          ],
          "type": "object"
        },
        "overallPassed": {
          "type": "boolean"
        },
        "passed": {
          "type": "boolean"
        },
        "protocolFailureReasons": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "protocolPassed": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "sessionID": {
          "type": "string"
        },
        "taskPassed": {
          "type": "boolean"
        }
      },
      "required": [
        "attempt",
        "passed",
        "reason",
        "taskPassed",
        "protocolPassed",
        "overallPassed",
        "protocolFailureReasons",
        "corruptionDetected",
        "metrics",
        "sessionID",
        "events"
      ],
      "type": "object"
    },
    "modelRef": {
      "properties": {
        "label": {
          "type": "string"
        },
        "modelID": {
          "type": "string"
        },
        "providerID": {
          "type": "string"
        }
      },
      "required": [
        "providerID",
        "modelID",
        "label"
      ],
      "type": "object"
    }
  },
  "$id": "https://hashline.dev/schemas/opencode-sdk-bench/run-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "config": {
      "properties": {
        "disturbance": {
          "type": "boolean"
        },
        "disturbanceProbability": {
          "type": "number"
        },
        "enforceProtocol": {
          "type": "boolean"
        },
        "fixtureSet": {
          "enum": [
            "default",
            "holdout",
            "all"
          ]
        },
        "fixturesDir": {
          "type": "string"
        },
        "mode": {
          "enum": [
            "hashline",
            "raw_replace",
            "patch"
          ]
        },
        "model": {
          "type": "string"
        },
        "randomize": {
          "type": "boolean"
        },
        "repeats": {
          "minimum": 1,
          "type": "integer"
        },
        "runsDir": {
          "type": "string"
        },
        "seed": {
          "type": "integer"
        },
        "sizes": {
          "items": {
            "enum": [
              "small",
              "mid",
              "large"
            ]
          },
          "minItems": 1,
          "type": "array"
        },
        "workspaceDir": {
          "type": "string"
        }
      },
      "required": [
        "workspaceDir",
        "fixturesDir",
        "runsDir",
        "mode",
        "repeats",
        "sizes"
      ],
      "type": "object"
    },
    "finishedAt": {
      "type": "string"
    },
    "model": {
      "$ref": "#/$defs/modelRef"
    },
    "results": {
      "items": {
        "properties": {
          "attempts": {
            "items": {
              "$ref": "#/$defs/attemptResult"
            },
            "minItems": 1,
            "type": "array"
          },
          "caseId": {
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "mode": {
            "enum": [
              "hashline",
              "raw_replace",
              "patch"
            ]
          },
          "model": {
            "$ref": "#/$defs/modelRef"
          },
          "size": {
            "enum": [
              "small",
              "mid",
              "large"
            ]
          }
        },
        "required": [
          "size",
          "caseId",
          "mode",
          "model",
          "attempts"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "startedAt": {
      "type": "string"
    }
  },
  "required": [
    "startedAt",
    "finishedAt",
    "config",
    "model",
    "results"
  ],
  "title": "OpenCode SDK Benchmark Run Report",
  "type": "object"
}
